version: 0.2
phases:
  install:
    # Commands to install dependencies
    runtime-versions:
      nodejs: 18
    commands:
      - echo Installing dependencies...
      - npm install
  build:
    # Commands to build the application
    commands:
      - echo Building the application...
      - npm run build
  post_build:
    # Commands to run tests or finalize artifacts
    commands:
      - echo Running tests...
      - npm test
artifacts:
  # Files to be packaged as artifacts for the next stage
  files:
    - '**/*'
  base-directory: 'build'
Resources:
  MyCodePipeline:
    Type: AWS::CodePipeline::Pipeline
    Properties:
      RoleArn: !GetAtt CodePipelineServiceRole.Arn
      ArtifactStore:
        Type: S3
        Location: !Ref ArtifactBucket
      Stages:
        - Name: Source
          Actions:
            - Name: SourceAction
              ActionType:
                Category: Source
                Provider: GitHub
                Version: '1'
              Configuration:
                Owner: "MyGitHubUser"
                Repo: "MyRepo"
                Branch: "main"
                # Use a connection for secure access
                ConnectionArn: !Ref GitHubConnectionArn
              OutputArtifacts:
                - Name: SourceArtifact
        - Name: Build
          Actions:
            - Name: Build
              ActionType:
                Category: Build
                Provider: CodeBuild
                InputArtifacts:
                  - Name: SourceArtifact
                OutputArtifacts:
                  - Name: BuildArtifact
                Configuration:
                  ProjectName: !Ref MyCodeBuildProject
        - Name: Deploy
          Actions:
            - Name: Deploy
              ActionType:
                Category: Deploy
                Provider: CodeDeploy
                InputArtifacts:
                  - Name: BuildArtifact
                Configuration:
                  ApplicationName: !Ref MyApplication
                  DeploymentGroupName: !Ref MyDeploymentGroup
